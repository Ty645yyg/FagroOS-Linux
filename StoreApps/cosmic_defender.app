{
  "name": "Космический защитник",
  "version": "1.0.0",
  "author": "DeepSeek #2",
  "icon": "👾",
  "description": "Аркадная игра — сбивай астероиды лазером!",
  "permissions": [],
  "code": "// КОСМИЧЕСКИЙ ЗАЩИТНИК\n// Сбивай падающие астероиды!\n\nprint \"👾 КОСМИЧЕСКИЙ ЗАЩИТНИК\"\nprint \"=======================\"\nprint \"Управление: ← и →, стрельба: пробел\"\nprint \"Нажми любую клавишу для старта\"\nwait_key()\n\n// Параметры игры\nwidth = 20\nplayer_pos = 10\nscore = 0\nasteroids = []\nlasers = []\nlives = 3\nlevel = 1\n\n// Функция отрисовки\nfunction draw() {\n    clear_screen()\n    \n    // Верхняя граница\n    print \"=\" * width\n    \n    // Игровое поле\n    for y = 0 to 10 {\n        line = \"\"\n        for x = 0 to width-1 {\n            cell = \" \"\n            \n            // Проверяем астероиды\n            for a in asteroids {\n                if a.x == x and a.y == y {\n                    cell = \"💎\"\n                }\n            }\n            \n            // Проверяем лазеры\n            for l in lasers {\n                if l.x == x and l.y == y {\n                    cell = \"⚡\"\n                }\n            }\n            \n            line = line + cell\n        }\n        print line\n    }\n    \n    // Нижняя граница с игроком\n    bottom = \"\"\n    for x = 0 to width-1 {\n        if x == player_pos {\n            bottom = bottom + \"🚀\"\n        } else {\n            bottom = bottom + \"-\"\n        }\n    }\n    print bottom\n    \n    // Статистика\n    print \"=\" * width\n    print \"❤️ Жизни: \" + lives + \"   🎯 Счёт: \" + score + \"   🌟 Уровень: \" + level\n}\n\n// Основной игровой цикл\nwhile lives > 0 {\n    // Создаём новые астероиды (чем выше уровень, тем больше)\n    if random(0, 10) < level {\n        asteroids.append({\n            x: random(0, width-1),\n            y: 0\n        })\n    }\n    \n    // Движение астероидов\n    new_asteroids = []\n    for a in asteroids {\n        a.y = a.y + 1\n        \n        // Проверка столкновения с игроком\n        if a.y == 10 and a.x == player_pos {\n            lives = lives - 1\n            print \"💥 ПОПАДАНИЕ! Осталось жизней: \" + lives\n            wait(500)\n            // Не добавляем астероид обратно\n        } else if a.y > 10 {\n            // Астероид улетел — штраф\n            score = score - 5\n        } else {\n            new_asteroids.append(a)\n        }\n    }\n    asteroids = new_asteroids\n    \n    // Движение лазеров\n    new_lasers = []\n    for l in lasers {\n        l.y = l.y - 1\n        \n        hit = false\n        // Проверка попадания в астероиды\n        new_asteroids2 = []\n        for a in asteroids {\n            if l.x == a.x and l.y == a.y {\n                hit = true\n                score = score + 10\n            } else {\n                new_asteroids2.append(a)\n            }\n        }\n        asteroids = new_asteroids2\n        \n        if not hit and l.y >= 0 {\n            new_lasers.append(l)\n        }\n    }\n    lasers = new_lasers\n    \n    // Отрисовка\n    draw()\n    \n    // Управление\n    key = get_key()\n    if key == \"left\" and player_pos > 0 {\n        player_pos = player_pos - 1\n    } elif key == \"right\" and player_pos < width-1 {\n        player_pos = player_pos + 1\n    } elif key == \"space\" {\n        lasers.append({\n            x: player_pos,\n            y: 9\n        })\n    }\n    \n    // Увеличение уровня каждые 100 очков\n    new_level = (score / 100) + 1\n    if new_level > level {\n        level = new_level\n        print \"✨ УРОВЕНЬ \" + level + \"! ✨\"\n        wait(1000)\n    }\n    \n    wait(100)\n}\n\n// Конец игры\nclear_screen()\nprint \"💀 ИГРА ОКОНЧЕНА 💀\"\nprint \"==================\"\nprint \"🎯 Финальный счёт: \" + score\nprint \"🌟 Максимальный уровень: \" + level\nprint \"\"\nprint \"Нажми любую клавишу для выхода\"\nwait_key()\nprint \"👾 Спасибо за игру!\""
}
