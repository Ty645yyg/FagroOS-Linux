{
  "name": "Мегавикторина",
  "version": "1.0.0",
  "author": "DeepSeek #2",
  "icon": "🧠",
  "description": "Проверь знания в 5 темах! История, IT, наука, география, искусство",
  "permissions": [],
  "code": "// МЕГАВИКТОРИНА\n// Проверь свои знания!\n\nprint \"🧠 МЕГАВИКТОРИНА v1.0\"\nprint \"======================\"\nprint \"Ответь на 10 вопросов и получи звание!\"\nprint \"\"\nprint \"Нажми любую клавишу для старта\"\nwait_key()\n\n// База вопросов\nquestions = [\n    // История\n    { text: \"Кто написал 'Войну и мир'?\", \n      options: [\"А. Пушкин\", \"Л. Толстой\", \"Ф. Достоевский\", \"И. Тургенев\"], \n      correct: 1, topic: \"📜 История\" },\n    { text: \"В каком году произошла Октябрьская революция?\", \n      options: [\"1905\", \"1917\", \"1921\", \"1914\"], \n      correct: 1, topic: \"📜 История\" },\n    \n    // IT\n    { text: \"Что означает HTML?\", \n      options: [\"Hyper Text Markup Language\", \"High Tech Modern Language\", \"Hyper Transfer Main Logic\", \"Home Tool Markup Language\"], \n      correct: 0, topic: \"💻 IT\" },\n    { text: \"Какой язык используется для нейросетей чаще всего?\", \n      options: [\"Java\", \"C++\", \"Python\", \"JavaScript\"], \n      correct: 2, topic: \"💻 IT\" },\n    \n    // Наука\n    { text: \"Какая планета самая большая в Солнечной системе?\", \n      options: [\"Сатурн\", \"Юпитер\", \"Нептун\", \"Уран\"], \n      correct: 1, topic: \"🔬 Наука\" },\n    { text: \"Что такое ДНК?\", \n      options: [\"Белок\", \"Углевод\", \"Нуклеиновая кислота\", \"Жир\"], \n      correct: 2, topic: \"🔬 Наука\" },\n    \n    // География\n    { text: \"Самая длинная река в мире?\", \n      options: [\"Амазонка\", \"Нил\", \"Янцзы\", \"Миссисипи\"], \n      correct: 0, topic: \"🌍 География\" },\n    { text: \"Столица Японии?\", \n      options: [\"Пекин\", \"Сеул\", \"Токио\", \"Осака\"], \n      correct: 2, topic: \"🌍 География\" },\n    \n    // Искусство\n    { text: \"Кто нарисовал 'Мону Лизу'?\", \n      options: [\"Ван Гог\", \"Пикассо\", \"Леонардо да Винчи\", \"Микеланджело\"], \n      correct: 2, topic: \"🎨 Искусство\" },\n    { text: \"Какой музыкальный инструмент считается королём?\", \n      options: [\"Скрипка\", \"Фортепиано\", \"Гитара\", \"Барабан\"], \n      correct: 1, topic: \"🎨 Искусство\" }\n]\n\nscore = 0\nanswers = []\n\n// Перемешиваем вопросы\nfor i = len(questions)-1 to 1 step -1 {\n    j = random(0, i)\n    temp = questions[i]\n    questions[i] = questions[j]\n    questions[j] = temp\n}\n\nprint \"\"\nprint \"🎯 НАЧИНАЕМ ВИКТОРИНУ!\"\nprint \"========================\"\nwait(1000)\n\n// Основной цикл вопросов\nfor i = 0 to len(questions)-1 {\n    q = questions[i]\n    \n    clear_screen()\n    print \"🧠 ВОПРОС \" + (i+1) + \"/\" + len(questions)\n    print \"🏷️  Тема: \" + q.topic\n    print \"\"\n    print q.text\n    print \"\"\n    \n    // Выводим варианты\n    for opt = 0 to len(q.options)-1 {\n        print \"  \" + (opt+1) + \". \" + q.options[opt]\n    }\n    \n    print \"\"\n    print \"Введи номер ответа (1-\" + len(q.options) + \"):\"\n    \n    // Получаем ответ\n    while true {\n        input answer\n        if answer >= 1 and answer <= len(q.options) {\n            break\n        }\n        print \"❌ Введи число от 1 до \" + len(q.options)\n    }\n    \n    // Проверяем\n    if answer-1 == q.correct {\n        print \"✅ ПРАВИЛЬНО! +10 очков\"\n        score = score + 10\n        answers.append({ q: q.text, correct: true, user: q.options[answer-1], right: q.options[q.correct] })\n    } else {\n        print \"❌ НЕПРАВИЛЬНО!\"\n        print \"Правильный ответ: \" + q.options[q.correct]\n        answers.append({ q: q.text, correct: false, user: q.options[answer-1], right: q.options[q.correct] })\n    }\n    \n    print \"\"\n    print \"Счёт: \" + score + \"/\" + ((i+1)*10)\n    \n    if i < len(questions)-1 {\n        print \"\"\n        print \"Нажми любую клавишу для следующего вопроса...\"\n        wait_key()\n    }\n}\n\n// Финальный экран\nclear_screen()\nprint \"🎉 ВИКТОРИНА ЗАВЕРШЕНА! 🎉\"\nprint \"==========================\"\nprint \"\"\nprint \"📊 ИТОГИ:\"\nprint \"   Правильных ответов: \" + (score/10) + \"/\" + len(questions)\nprint \"   Набрано очков: \" + score + \"/\" + (len(questions)*10)\nprint \"\"\n\n// Звание\npercent = (score / (len(questions)*10)) * 100\nif percent == 100 {\n    rank = \"🏆 ГЕНИЙ! 🏆\"\n} elif percent >= 80 {\n    rank = \"🎓 ЭРУДИТ\"\n} elif percent >= 60 {\n    rank = \"📚 ЗНАТОК\"\n} elif percent >= 40 {\n    rank = \"📖 УЧЕНИК\"\n} else {\n    rank = \"🌱 НОВИЧОК\"\n}\n\nprint \"🏅 ЗВАНИЕ: \" + rank\nprint \"\"\n\n// Показываем ошибки\nwrong = []\nfor a in answers {\n    if not a.correct {\n        wrong.append(a)\n    }\n}\n\nif len(wrong) > 0 {\n    print \"📝 РАЗБОР ОШИБОК:\"\n    print \"=================\"\n    for w in wrong {\n        print \"❓ \" + w.q\n        print \"   Твой ответ: \" + w.user\n        print \"   ✅ Правильно: \" + w.right\n        print \"\"\n    }\n}\n\nprint \"💡 Хочешь сыграть ещё? (да/нет)\"\ninput again\n\nif again == \"да\" or again == \"д\" or again == \"yes\" {\n    print \"🔄 Перезапуск...\"\n    run_self()\n} else {\n    print \"👋 Спасибо за игру! Возвращайся!\"\n    wait(1500)\n}"
}
